  "keyFeatures": [
    "Shared apartment management with multi-user access",
    "Expense tracking and automatic debt calculation",
    "Task assignment with calendar-based scheduling",
    "Role-based access control (coordinators and members)",
    "Odoo ERP integration for financial management",
    "Real-time synchronization across roommates",
    "Multi-language support (Basque, Spanish)",
    "Docker-based deployment architecture"
  ],
  "publicApiSurface": [
    "POST /pisua - Create new apartment",
    "POST /pisua/batu - Join existing apartment",
    "GET /pisua/kideak - Get apartment members",
    "POST /gastuak/addGastua - Add expense",
    "GET /gastos/{idPisua}/{idErabiltzailea} - Get expenses",
    "POST /pagos/saldar - Settle debts",
    "GET /zereginak - List tasks",
    "POST /zereginak - Create task",
    "PUT /zereginak/{zeregina} - Update task",
    "DELETE /zereginak/{zeregina} - Delete task",
    "PUT /pisua/{pisuaId}/kidea/{memberId}/promote - Promote member to coordinator",
    "DELETE /pisua/{pisuaId}/kidea/{memberId}/remove - Remove member from apartment"
  ]
}
